{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "turbo": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint './**/*.{ts,tsx}'",
    "eslint-inspect": "npx @eslint/config-inspector@latest",
    "lint:fix": "eslint './**/*.{ts,tsx}' --fix",
    "format": "prettier --write . --ignore-path .gitignore",
    "unused": "yarn ts-unused-exports tsconfig.json --excludeDeclarationFiles --showLineNumber '--excludePathsFromReport=pages' '--ignoreFiles=.*config.*|.*.stories.*'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes --only-changed",
    "cypress": "cypress open",
    "e2e:local": "node scripts/cy-test.mjs",
    "cy:test": "yarn run e2e:local",
    "prepare": "husky install",
    "upgrade:linter": "yarn up 'eslint*'",
    "upgrade:types": "yarn up '@types/*' '*typescript*'",
    "upgrade:storybook": "npx storybook@latest upgrade",
    "create-stories": "node scripts/create-stories.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "bracketSpacing": true,
    "printWidth": 100
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@formspree/react": "^3.0.0",
    "@headlessui/react": "^2.2.9",
    "@notionhq/client": "^5.12.0",
    "@radix-ui/react-label": "^2.0.1",
    "@radix-ui/react-separator": "^1.0.2",
    "@vercel/analytics": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jotai": "^2.6.1",
    "motion": "^12.18.1",
    "next": "^16.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.3.0",
    "react-textarea-autosize": "^8.5.3",
    "swr": "^2.2.4",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.55.1",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-links": "^10.2.17",
    "@storybook/nextjs": "^10.2.17",
    "@swc/core": "^1.12.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/gtag.js": "^0.0.20",
    "@types/jsdom": "^28",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.16",
    "chromatic": "^15.2.0",
    "cspell": "latest",
    "cypress": "^15.11.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-css": "0.12.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "^10.2.17",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.6",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "postcss": "^8.4.34",
    "prettier": "^3.1.1",
    "storybook": "^10.2.17",
    "storybook-addon-pseudo-states": "^10.2.17",
    "tailwindcss": "^4.2.1",
    "ts-prune": "^0.10.3",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^4.1.0"
  },
  "packageManager": "yarn@4.0.2",
  "volta": {
    "node": "22.16.0",
    "yarn": "4.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "resolutions": {
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "tar": "7.5.11",
    "pbkdf2": "3.1.3",
    "sha.js": "2.4.12",
    "cipher-base": "1.0.5",
    "form-data": "4.0.4",
    "serialize-javascript": "7.0.3",
    "lodash": "4.17.23",
    "qs": "6.14.2",
    "js-yaml": "4.1.1",
    "minimatch@^3.0.4": "3.1.5",
    "minimatch@^3.1.1": "3.1.5",
    "minimatch@^3.1.2": "3.1.5",
    "minimatch@^9.0.1": "9.0.9",
    "ip": "2.0.1",
    "postcss@^8.2.14": "8.4.47",
    "postcss@^8.4.21": "8.4.47",
    "tmp": "0.2.4",
    "glob@^10.2.2": "10.5.0",
    "glob@^10.3.7": "10.5.0",
    "webpack": "5.104.1"
  }
}
