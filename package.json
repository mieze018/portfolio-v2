{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "turbo": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint './**/*.{ts,tsx}'",
    "lint-": "next lint",
    "eslint-inspect": "npx @eslint/config-inspector@latest",
    "lint:fix": "next lint --fix --no-cache",
    "format": "prettier --write . --ignore-path .gitignore",
    "unused": "yarn ts-unused-exports tsconfig.json --excludeDeclarationFiles --showLineNumber '--excludePathsFromReport=pages' '--ignoreFiles=.*config.*|.*.stories.*'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes --only-changed",
    "cypress": "cypress open",
    "cy:test": "kill $(lsof -i :3009 | grep node | awk '{print $2}') & next build && next start --port 3009 & cypress run --browser chrome && kill $(lsof -i :3009 | grep node | awk '{print $2}') ",
    "prepare": "husky install",
    "upgrade:linter": "yarn up 'eslint*'",
    "upgrade:types": "yarn up '@types/*' '*typescript*'",
    "upgrade:storybook": "npx storybook@latest upgrade",
    "create-stories": "node scripts/create-stories.mjs"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "bracketSpacing": true,
    "printWidth": 100
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@formspree/react": "^2.5.1",
    "@headlessui/react": "^1.7.17",
    "@notionhq/client": "^3.1.3",
    "@radix-ui/react-label": "^2.0.1",
    "@radix-ui/react-separator": "^1.0.2",
    "@vercel/analytics": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jotai": "^2.6.1",
    "motion": "^12.18.1",
    "next": "15.3.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-icons": "^5.3.0",
    "react-textarea-autosize": "^8.5.3",
    "swr": "^2.2.4",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.0.0",
    "@eslint/js": "^9.11.1",
    "@playwright/test": "^1.40.1",
    "@storybook/addon-a11y": "^9.0.9",
    "@storybook/addon-docs": "9.0.9",
    "@storybook/addon-links": "^9.0.9",
    "@storybook/nextjs": "^9.0.9",
    "@swc/core": "^1.12.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/gtag.js": "^0.0.20",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.16",
    "chromatic": "^15.2.0",
    "cspell": "latest",
    "cypress": "^14.0.3",
    "eslint": "^10.0.3",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-css": "^0.12.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "^10.2.17",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.6",
    "postcss": "^8.4.34",
    "prettier": "^3.1.1",
    "storybook": "^9.0.9",
    "storybook-addon-pseudo-states": "^9.0.9",
    "tailwindcss": "^3.4.0",
    "ts-prune": "^0.10.3",
    "ts-unused-exports": "^10.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "volta": {
    "node": "22.16.0",
    "yarn": "4.0.2"
  },
  "resolutions": {
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
