{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.classAttributes": ["class", "className", "ngClass"],
  "tailwindCSS.classFunctions": ["cva", "cx", "tw"],

  "tailwindCSS.includeLanguages": {
    "typescript": "javascript",
    "typescriptreact": "javascript"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.addMissingImports": "explicit",
    "source.organizeImports.biome": "explicit"
  },
  "workbench.colorCustomizations": {
    "activityBar.background": "#2a2a2a",
    "titleBar.activeBackground": "#ff5e00",
    "titleBar.activeForeground": "#F8F9FD"
  },
  "i18n-ally.localesPaths": ["public/locales"],
  "i18n-ally.keystyle": "flat",
  // 各言語別にフォーマッターを設定
  "[json]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[tsx]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[mdx]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "unifiedjs.vscode-mdx"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  // ESLint は Biome に移行済みのため不要だが、既存設定との互換性のために残す
  "chat.promptFilesRecommendations": {
    "speckit.constitution": true,
    "speckit.specify": true,
    "speckit.plan": true,
    "speckit.tasks": true,
    "speckit.implement": true
  },
  "chat.tools.terminal.autoApprove": {
    ".specify/scripts/bash/": true,
    ".specify/scripts/powershell/": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  }
}
