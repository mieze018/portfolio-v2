#!/bin/sh
# Why: Volta v2 on Windows のデータディレクトリは %LOCALAPPDATA%\Volta。
#      旧来の ~/.volta（macOS/Linux形式）は無効。
#      VOLTA_HOME が空だと Volta シムが node のパスを解決できず
#      'node is not recognized' エラーになるため、明示的に設定する。
#      PATH は Git Bash 起動時に既に Volta bin を含むため変更不要。
export VOLTA_HOME="${LOCALAPPDATA}\\Volta"

pnpm lint-staged
