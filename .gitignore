# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Claude Code (ローカルのツール許可設定。個人環境依存のため除外)
# Why: .claude/ 全体を除外すると子ディレクトリのネゲートが効かないため、
# 個別ファイルを除外し skills/ だけバージョン管理する
.claude/*
!.claude/skills/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/test-results/
/playwright-report/
/playwright/.cache/
build-storybook.log

.vercel
.env
cypress/screenshots/*
cypress/videos/*

*storybook.log
/storybook-static
/.playwright-mcp

# graphify
graphify-out/
